{
  "name": "agentic-code-review-bot",
  "version": "1.0.0",
  "description": "GitHub Action that uses an LLM agent to orchestrate static analysis tools and post PR reviews",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "review": "ts-node src/cli.ts",
    "action": "node dist/index.js",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "package": "ncc build src/index.ts -o dist --source-map --license licenses.txt"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^21.0.2",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.13.0",
    "minimist": "^1.2.8",
    "openai": "^4.68.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.13",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.7.5",
    "@vercel/ncc": "^0.44.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "setupFiles": [
      "<rootDir>/tests/setup.ts"
    ]
  }
}
